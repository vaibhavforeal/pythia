# ── Azure AI Foundry (Claude served via Foundry's Anthropic Messages API) ────
# Only the chat step calls the network; the birth-chart and Guna-Milan math run
# fully offline, so the app still boots and casts charts without these set.

# The FULL Anthropic messages URL for your Foundry Claude deployment, e.g.
#   https://<resource>.services.ai.azure.com/anthropic/v1/messages
AZURE_INFERENCE_ENDPOINT=

# The endpoint key (Azure portal / Foundry → Keys & Endpoint). Sent as `x-api-key`.
AZURE_INFERENCE_KEY=

# The deployed model / deployment name (e.g. your Claude deployment).
AZURE_DEPLOYMENT=claude-opus-4-8-2

# ── Authentication ──────────────────────────────────────────────────────────
# Secret used to sign session cookies. Generate one, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If unset, a random one is used and everyone is logged out on restart.
SESSION_SECRET=

# Set to true when serving over HTTPS (production) so session cookies are
# marked Secure. Leave false for local http://localhost.
COOKIE_SECURE=false

# ── Data store ──────────────────────────────────────────────────────────────
# Supabase Postgres (recommended for hosting). From your Supabase project →
# Settings → API. Use the SERVICE ROLE key — server-side only, keep it secret.
# Run supabase/schema.sql once in the SQL editor first.
# If both are unset, the app falls back to local JSON files under server/data.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Optional — where the local JSON fallback stores data (default server/data).
# DATA_DIR=

# Optional — server port (defaults to 3030). Most hosts inject PORT for you.
# PORT=3030

# ── Chat rate limits (per logged-in user; optional) ─────────────────────────
# CHAT_RPM=20    # max chat messages per minute (default 20)
# CHAT_RPD=300   # max chat messages per day (default 300)

# --- Google Sign-In (optional) ---
# Create an OAuth 2.0 Client ID (type: Web application) at
# https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs must include:
#   http://localhost:3030/api/auth/google/callback   (local dev)
#   https://<your-app>.onrender.com/api/auth/google/callback   (production)
# Leave these unset to hide the "Continue with Google" button.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional: force the exact redirect URI (otherwise derived from the request host)
GOOGLE_REDIRECT_URI=
